# Founder Systems API production environment
# All settings are read with the FS_ prefix.

FS_APP_NAME=Founder Systems API
FS_ENV=production

# Use Postgres in production.
FS_DATABASE_URL=postgresql+psycopg://founder_systems:CHANGE_ME@127.0.0.1:5432/founder_systems

# Generate a long random value, for example: openssl rand -hex 32
FS_SESSION_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
FS_SESSION_COOKIE_NAME=fs_session
FS_SESSION_COOKIE_DOMAIN=.foundersystems.in
FS_SESSION_COOKIE_SECURE=true
FS_SESSION_MAX_AGE_SECONDS=2592000

FS_MAGIC_LINK_TTL_MINUTES=20

FS_SITE_APP_URL=https://foundersystems.in
FS_ACCOUNT_APP_URL=https://account.foundersystems.in
FS_PROMPTDECK_APP_URL=https://promptdeck.foundersystems.in

# Tighten this regex to the exact production frontends allowed to call the API.
FS_CORS_ORIGIN_REGEX=^https://(foundersystems\.in|account\.foundersystems\.in|promptdeck\.foundersystems\.in)$

# Required for production email delivery. Without these, magic links only print to stdout.
FS_RESEND_API_KEY=re_xxx
FS_RESEND_FROM_EMAIL=Founder Systems <login@foundersystems.in>

# Required for real payments and webhook verification.
FS_RAZORPAY_KEY_ID=rzp_live_xxx
FS_RAZORPAY_KEY_SECRET=CHANGE_ME
FS_RAZORPAY_WEBHOOK_SECRET=CHANGE_ME
FS_ALLOW_MOCK_PAYMENTS=false

# Optional: reserved for internal service-to-service callers.
FS_API_KEY_INTERNAL=
FS_ADMIN_EMAILS=admin@foundersystems.in

# Catalog defaults seeded on startup.
FS_PROMPTDECK_PRICE_INR_MINOR=149900
FS_PROMPTDECK_PRICE_USD_MINOR=1900
FS_PROMPTDECK_CREDIT_GRANT=3
