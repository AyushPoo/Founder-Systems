FS_ENV=production
FS_APP_NAME=Founder Systems API

# Postgres is recommended in production.
# Example:
# postgresql+psycopg://foundersystems:change-me@127.0.0.1:5432/founder_systems
FS_DATABASE_URL=postgresql+psycopg://foundersystems:change-me@127.0.0.1:5432/founder_systems

# Shared auth cookie for all Founder Systems properties.
FS_SESSION_COOKIE_NAME=fs_session
FS_SESSION_SECRET=replace-with-a-long-random-secret
FS_SESSION_COOKIE_DOMAIN=.foundersystems.in
FS_SESSION_COOKIE_SECURE=true
FS_SESSION_MAX_AGE_SECONDS=2592000

# Passwordless auth
FS_MAGIC_LINK_TTL_MINUTES=20
FS_ACCOUNT_APP_URL=https://account.foundersystems.in
FS_SITE_APP_URL=https://foundersystems.in
FS_PROMPTDECK_APP_URL=https://promptdeck.foundersystems.in

# Email delivery for magic links
FS_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
FS_RESEND_FROM_EMAIL=Founder Systems <auth@foundersystems.in>

# Razorpay checkout + webhook verification
FS_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
FS_RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
FS_RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx
FS_ALLOW_MOCK_PAYMENTS=false

# Internal service-to-service protection
FS_API_KEY_INTERNAL=replace-with-a-second-long-random-secret
FS_ADMIN_EMAILS=admin@foundersystems.in,founder@example.com

# Optional override for shared-site CORS.
FS_CORS_ORIGIN_REGEX=https?://([a-z0-9-]+\.)?foundersystems\.in(:\d+)?$

# PromptDeck v1 launch SKU
FS_PROMPTDECK_PRICE_INR_MINOR=149900
FS_PROMPTDECK_PRICE_USD_MINOR=1900
FS_PROMPTDECK_CREDIT_GRANT=3
